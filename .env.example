# Copy this file to .env and adjust values for your machine.
# Docker Compose automatically reads .env from the project root.
#
# Note: Ollama host cache path is currently hardcoded in docker-compose.yml:
#   D:/data/ollama-data:/root/.ollama
# If your machine has no D: drive, edit docker-compose.yml directly.

# --- Model/token access ---
HF_TOKEN=hf_xxx_your_token
QWEN3_TTS_IMAGE=qwen3-tts-api:blackwell-local
OLLAMA_MODEL=phi3:mini
# Optional overrides
# OLLAMA_MODEL=qwen3:4b
# TTS_MODEL=Qwen/Qwen3-TTS-12Hz-0.6B-CustomVoice
GRADIO_HOST=0.0.0.0
TTS_VOICE=Ono_Anna
MOUTH_OPEN_VALUE=0.5

# Optional comma-separated pre-pull list for Ollama container startup.
OLLAMA_PULL_MODELS=phi3:mini,llava:7b
OLLAMA_VISION_MODEL=llava:7b
STREAMER_VISION_MODEL=llava:7b

# --- Core service/runtime ---
INTERACTION_WS_PORT=8001
TZ=America/New_York
APP_TIMEZONE=America/New_York

# --- Streamer options ---
STREAMER_STT_ENABLED=0
STREAMER_TTS_ENABLED=0
STREAMER_OBS_HOST=host.docker.internal
STREAMER_OBS_PORT=4455
STREAMER_OBS_PASSWORD=
STREAMER_OBS_SOURCE_NAME=
STREAMER_OBS_WIDTH=960
STREAMER_OBS_HEIGHT=540
STREAMER_OBS_MIN_INTERVAL_MS=400
STREAMER_STT_MODEL_SIZE=small
STREAMER_STT_LANGUAGE=en

# --- Outlook bridge (required for calendar features from Docker) ---
OUTLOOK_BRIDGE_URL=http://host.docker.internal:8765
OUTLOOK_BRIDGE_TIMEOUT_SEC=25
